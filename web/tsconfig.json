{
  "compilerOptions": {
    "allowJs": false,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "src/api/**/*.ts",
    "src/domain/constants.d.ts",
    "src/domain/csv.ts",
    "src/domain/planner.ts",
    "src/domain/types.ts"
  ]
}
